{
  "name": "Validate Senzing JSON Output",
  "version": "1.0.0",
  "description": "Validate Senzing JSON format when transformation output files are created or modified",
  "when": {
    "type": "fileEdited",
    "patterns": ["data/transformed/*.jsonl", "data/transformed/*.json"]
  },
  "then": {
    "type": "askAgent",
    "prompt": "Senzing JSON output was modified. Please use the lint_record MCP tool to validate a sample of records from this file to ensure they conform to the Senzing Generic Entity Specification."
  }
}
