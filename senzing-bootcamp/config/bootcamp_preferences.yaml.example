# Bootcamp Preferences
# User choices persisted during onboarding and ongoing sessions.
# This file is created during onboarding and updated throughout.
# Copy this file to bootcamp_preferences.yaml to use as a starting point.

# Programming language (set during onboarding)
language: null

# Selected track (set during onboarding)
track: null

# Infrastructure settings (set during Module 1 or Module 8+)
deployment_target: null
cloud_provider: null
database_type: sqlite

# Session behavior (set during onboarding or mid-session)
verbosity: null
conversation_style: null

# Mapping-specific verbosity (set during Module 5 Phase 2)
# Values: verbose, concise, or null (not yet asked)
mapping_verbosity: null

# Installed hooks (populated during onboarding and module starts)
hooks_installed: []

# Pacing adjustments (updated mid-session)
pacing_overrides: null
